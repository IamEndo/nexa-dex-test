# === NexaDEX Environment Configuration ===

# Server
NEXADEX_HOST=0.0.0.0
NEXADEX_PORT=9090

# Database (PostgreSQL)
NEXADEX_DB_URL=jdbc:postgresql://localhost:5432/nexadex
NEXADEX_DB_USER=nexadex
NEXADEX_DB_PASSWORD=nexadex
NEXADEX_DB_POOL_SIZE=10

# Rostrum (Nexa blockchain node)
# Use electrum.nexa.org (NOT rostrum.nexa.org — cert mismatch)
NEXADEX_ROSTRUM_URL=wss://electrum.nexa.org:20004
NEXADEX_ROSTRUM_SSL=true

# Rate limiting
NEXADEX_RATE_LIMIT=120
NEXADEX_SWAP_RATE_LIMIT=30

# Trading limits
NEXADEX_MAX_SLIPPAGE_BPS=500
NEXADEX_MAX_PRICE_IMPACT_BPS=1500
NEXADEX_MIN_TRADE_SATS=546
NEXADEX_TRADE_TIMEOUT_MS=30000

# Indexer
NEXADEX_RECONCILE_INTERVAL_MS=600000
NEXADEX_CONFIRMATION_BLOCKS=1

# CORS (comma-separated origins, empty = allow all)
NEXADEX_CORS_ORIGINS=http://localhost:3000
